# Auth.js secret used to sign session cookies and JWTs.
AUTH_SECRET="replace-with-a-long-random-string"

# Runtime database connection. Prefer a pooled URL in serverless production.
# If your provider gives you only one URL, use the same value for both.
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
PRISMA_DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional direct/non-pooled URL used by `prisma migrate deploy`.
# Vercel Postgres also exposes POSTGRES_URL_NON_POOLING automatically.
DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"
PRISMA_MIGRATE_DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
