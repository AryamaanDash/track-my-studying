# Auth.js secret used to sign session cookies and JWTs.
AUTH_SECRET="replace-with-a-long-random-string"

# Runtime database connection. If your provider gives you only one URL,
# use the same value for both DATABASE_URL and PRISMA_DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
PRISMA_DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
